# Database
DATABASE_URL=postgresql://user:password@localhost:5432/resonans

# LLM API (velg en)
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Google Chat Webhook (for notifications)
GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/...

# Web Push / PWA notifications
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_public_vapid_key_here
VAPID_PRIVATE_KEY=your_private_vapid_key_here
VAPID_SUBJECT=mailto:hello@example.com

# Withings API (for health data integration)
# Get credentials at: https://developer.withings.com/
WITHINGS_CLIENT_ID=your_client_id_here
WITHINGS_CLIENT_SECRET=your_client_secret_here

# Dropbox API (for TCX/GPX workout file import)
# Create an app at: https://www.dropbox.com/developers/apps
DROPBOX_CLIENT_ID=your_client_id_here
DROPBOX_CLIENT_SECRET=your_client_secret_here

# SpareBank 1 API (read-only bank data integration)
# OAuth docs: https://developer.sparebank1.no/
SPAREBANK1_CLIENT_ID=your_client_id_here
SPAREBANK1_CLIENT_SECRET=your_client_secret_here
# Optional overrides (defaults are set in code)
# SPAREBANK1_API_BASE_URL=https://api.sparebank1.no
# SPAREBANK1_FINANCIAL_INSTITUTION=fid-smn
# SPAREBANK1_SCOPES=accounts
# SPAREBANK1_AUTHORIZE_ENDPOINT=/oauth/authorize
# SPAREBANK1_TOKEN_ENDPOINT=/oauth/token
# SPAREBANK1_HELLOWORLD_ENDPOINT=/common/helloworld
# Data endpoints (defaults are correct for SpareBank 1 prod):
# SPAREBANK1_ACCOUNTS_ENDPOINT=/personal/banking/accounts
# SPAREBANK1_TRANSACTIONS_ENDPOINT=/personal/banking/transactions

# App
PUBLIC_APP_NAME=Resonans
